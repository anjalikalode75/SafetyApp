<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <!-- Profile Section right Left -->
    <LinearLayout
        android:id="@+id/profileContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_alignParentEnd="true"
        android:layout_alignParentTop="true"
        android:layout_margin="16dp"
        android:padding="10dp"
        android:background="@drawable/circle_white_bg"
        android:elevation="8dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?android:attr/selectableItemBackgroundBorderless">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/profile_icon"
            android:contentDescription="Profile"/>

        <TextView
            android:id="@+id/tvProfile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Profile"
            android:textStyle="bold"
            android:textSize="14sp"
            android:textColor="#6A5ACD"
            android:layout_marginStart="6dp"/>

    </LinearLayout>

    <!-- Scroll Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/profileContainer"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/mainLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Welcome Section -->
            <TextView
                android:id="@+id/tvWelcome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Stay Safe 💜"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="#1F1F1F"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your safety is our priority"
                android:textSize="15sp"
                android:textColor="#555555"
                android:layout_marginBottom="28dp" />

            <!-- Add Trusted Contact Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="28dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Add Trusted Contact"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="#F4E5E5"
                        android:layout_marginBottom="14dp" />

                    <EditText
                        android:id="@+id/etContact"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:hint="Enter Phone Number"
                        android:inputType="phone"
                        android:background="@drawable/edittext_background"
                        android:paddingStart="16dp"
                        android:textSize="16sp" />

                    <Button
                        android:id="@+id/btnSaveContact"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:text="➕ Add Contact"
                        android:layout_marginTop="18dp"
                        android:backgroundTint="#6A5ACD"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:elevation="6dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Trusted Contacts -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Trusted Contacts"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="#333333"
                android:layout_marginBottom="12dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="200dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp"
                android:layout_marginBottom="32dp">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerContacts"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="12dp"
                    android:scrollbars="none" />

            </androidx.cardview.widget.CardView>

            <!-- SOS Button -->
            <Button
                android:id="@+id/btnSOS"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:text="🚨 SEND EMERGENCY SOS"
                android:textSize="21sp"
                android:textStyle="bold"
                android:backgroundTint="#D32F2F"
                android:textColor="#FFFFFF"
                android:elevation="12dp"
                android:layout_marginBottom="22dp" />

            <!-- Siren Button -->
            <Button
                android:id="@+id/btnSiren"
                android:layout_width="match_parent"
                android:layout_height="65dp"
                android:text="🔊 Toggle Emergency Siren"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="#FF9800"
                android:textColor="#FFFFFF"
                android:elevation="8dp"
                android:layout_marginBottom="22dp" />

        </LinearLayout>
    </ScrollView>

</RelativeLayout>