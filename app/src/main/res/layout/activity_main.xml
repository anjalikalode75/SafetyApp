<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="#F5F7FA"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 🔝 TOP BAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:padding="12dp"
        android:background="#FFFFFF"
        android:gravity="center_vertical"
        android:elevation="6dp">

        <ImageView
            android:id="@+id/btnProfile"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/profile_icon"
            android:contentDescription="Profile Button"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="👧 Girls Safety 🚨"
            android:textStyle="bold"
            android:textSize="18sp"
            android:gravity="center"
            android:textColor="#000000"/>

        <ImageView
            android:id="@+id/btnSettings"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/settings_icon"
            android:contentDescription="Settings Button"/>
    </LinearLayout>

    <!-- Safety Quote -->
    <TextView
        android:id="@+id/tvSafetyQuote"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Empower yourself, stay protected💪🛡️"
        android:textSize="14sp"
        android:textColor="#616161"
        android:gravity="center"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="8dp"
        android:fontFamily="sans-serif-medium"/>

    <!-- Live Tracking / Current SOS Location Button -->
    <Button
        android:id="@+id/btnLiveTracking"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="📍Current SOS Location"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:background="@drawable/btn_live_tracking_bg"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="8dp"
        android:elevation="6dp"/>

    <!-- 🗺️ MAP PREVIEW -->
    <ImageView
        android:id="@+id/mapPreview"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:scaleType="centerCrop"
        android:src="@drawable/map_placeholder"
        android:layout_margin="16dp"
        android:background="@drawable/map_card_bg"/>

    <!-- 🚨 SOS BUTTON -->
    <Button
        android:id="@+id/btnSOS"
        android:layout_width="match_parent"
        android:layout_height="107dp"
        android:layout_margin="16dp"
        android:background="@drawable/btn_sos_bg"
        android:text="🚨 SOS"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold" />

    <!-- 📞 SAVE CONTACT BUTTON -->
    <Button
        android:id="@+id/btnSaveContact"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/btn_save_bg"
        android:text="Save Trusted Contacts"
        android:textColor="#FFFFFF"
        android:textStyle="bold" />

</LinearLayout>